{
    "$schema": "https://schemas.wp.org/wp/6.9/theme.json",
    "version": 3,
    "customTemplates": [
        {
            "name": "page-no-title",
            "postTypes": ["page"],
            "title": "Page No Title"
        }
    ],
    "settings": {
        "appearanceTools": true,
        "color": {
            "defaultDuotone": false,
            "defaultGradients": false,
            "defaultPalette": false,
            "gradients": [
                {
                    "gradient": "linear-gradient(180deg, #6C080A 0%, #9D272D 100%)",
                    "name": "Gradient Accent",
                    "slug": "blnt-gradient-accent"
                },
                {
                    "gradient": "radial-gradient(164.05% 124.18% at 50% 124.18%, #000000 1.44%, #7A1E2B 10.58%, rgba(0, 0, 0, 0) 55.77%, rgba(0, 0, 0, 0) 100%)",
                    "name": "Gradient Background",
                    "slug": "blnt-gradient-background"
                },
                {
                    "gradient": "radial-gradient(104.44% 357.81% at 6.11% 44.67%, rgba(0, 0, 0, 0.8) 45.67%, rgba(122, 30, 43, 0.8) 100%)",
                    "name": "Radial Gradient",
                    "slug": "blnt-radial-gradient"
                },
                {
                    "gradient": "radial-gradient(164.05% 124.18% at 50% 124.18%, #000000 1.44%, #7A1E2B 10.58%, rgba(0, 0, 0, 0) 55.77%, rgba(0, 0, 0, 0) 100%)",
                    "name": "Radial Gradient 2",
                    "slug": "blnt-radial-gradient-2"
                },
                {
                    "gradient": "linear-gradient(180deg, #9D272D 6.73%, #6C080A 54%, rgba(221, 66, 66, 0) 100%)",
                    "name": "Linear Gradient",
                    "slug": "blnt-linear-gradient"
                },
                {
                    "gradient": "linear-gradient(90.21deg, #191919 44.34%, #7A1E2B 99.76%)",
                    "name": "Linear Gradient 2",
                    "slug": "blnt-linear-gradient-2"
                },
                {
                    "gradient": "linear-gradient(180deg, #FFFFFF 0%, #FFFFFF 0%, rgba(221, 66, 66, 0.20) 100%)",
                    "name": "Linear",
                    "slug": "blnt-linear"
                }
            ],
            "palette": [
                {
                    "color": "#FFFFFF",
                    "name": "White",
                    "slug": "blnt-white"
                },
                {
                    "color": "#f2f2f2",
                    "name": "Off White",
                    "slug": "blnt-off-white"
                },
                {
                    "color": "#e4e2df",
                    "name": "Light Gray",
                    "slug": "blnt-light-gray"
                },
                {
                    "color": "#000000",
                    "name": "Black",
                    "slug": "blnt-black"
                },
                {
                    "color": "#7a1e2b",
                    "name": "Red",
                    "slug": "blnt-red"
                }
            ]
        },
        "layout": {
            "contentSize": "1280px",
            "wideSize": "1440px"
        },
        "spacing": {
            "defaultSpacingSizes": false,
            "spacingSizes": [
                {
                    "name": "Tiny",
                    "size": "10px",
                    "slug": "blnt-10"
                },
                {
                    "name": "X-Small",
                    "size": "20px",
                    "slug": "blnt-20"
                },
                {
                    "name": "Small",
                    "size": "30px",
                    "slug": "blnt-30"
                },
                {
                    "name": "Regular",
                    "size": "clamp(30px, 5vw, 50px)",
                    "slug": "blnt-50"
                },
                {
                    "name": "Large",
                    "size": "clamp(30px, 7vw, 70px)",
                    "slug": "blnt-60"
                },
                {
                    "name": "X-Large",
                    "size": "clamp(70px, 7vw, 100px)",
                    "slug": "blnt-100"
                },
                {
                    "name": "XX-Large",
                    "size": "clamp(70px, 10vw, 140px)",
                    "slug": "blnt-140"
                }
            ],
            "units": ["%", "px", "em", "rem", "vh", "vw"]
        },
        "typography": {
            "defaultFontSizes": false,
            "fluid": true,
            "fontFamilies": [
                {
                    "name": "Inter",
                    "slug": "inter",
                    "fontFamily": "Inter, sans-serif",
                    "fontFace": [
                        {
                            "src": ["file:./assets/fonts/inter/inter-300-normal.woff2"],
                            "fontWeight": "300",
                            "fontStyle": "normal",
                            "fontFamily": "Inter"
                        },
                        {
                            "src": ["file:./assets/fonts/inter/inter-400-normal.woff2"],
                            "fontWeight": "400",
                            "fontStyle": "normal",
                            "fontFamily": "Inter"
                        },
                        {
                            "src": ["file:./assets/fonts/inter/inter-500-normal.woff2"],
                            "fontWeight": "500",
                            "fontStyle": "normal",
                            "fontFamily": "Inter"
                        },
                        {
                            "src": ["file:./assets/fonts/inter/inter-600-normal.woff2"],
                            "fontWeight": "600",
                            "fontStyle": "normal",
                            "fontFamily": "Inter"
                        },
                        {
                            "src": ["file:./assets/fonts/inter/inter-700-normal.woff2"],
                            "fontWeight": "700",
                            "fontStyle": "normal",
                            "fontFamily": "Inter"
                        },
                        {
                            "src": ["file:./assets/fonts/inter/inter-800-normal.woff2"],
                            "fontWeight": "800",
                            "fontStyle": "normal",
                            "fontFamily": "Inter"
                        },
                        {
                            "src": ["file:./assets/fonts/inter/inter-300-italic.woff2"],
                            "fontWeight": "300",
                            "fontStyle": "italic",
                            "fontFamily": "Inter"
                        },
                        {
                            "src": ["file:./assets/fonts/inter/inter-400-italic.woff2"],
                            "fontWeight": "400",
                            "fontStyle": "italic",
                            "fontFamily": "Inter"
                        },
                        {
                            "src": ["file:./assets/fonts/inter/inter-500-italic.woff2"],
                            "fontWeight": "500",
                            "fontStyle": "italic",
                            "fontFamily": "Inter"
                        },
                        {
                            "src": ["file:./assets/fonts/inter/inter-600-italic.woff2"],
                            "fontWeight": "600",
                            "fontStyle": "italic",
                            "fontFamily": "Inter"
                        },
                        {
                            "src": ["file:./assets/fonts/inter/inter-700-italic.woff2"],
                            "fontWeight": "700",
                            "fontStyle": "italic",
                            "fontFamily": "Inter"
                        },
                        {
                            "src": ["file:./assets/fonts/inter/inter-800-italic.woff2"],
                            "fontWeight": "800",
                            "fontStyle": "italic",
                            "fontFamily": "Inter"
                        }
                    ]
                },
                {
                    "name": "Baskervville",
                    "slug": "baskervville",
                    "fontFamily": "Baskervville, serif",
                    "fontFace": [
                        {
                            "src": ["file:./assets/fonts/baskervville/baskervville-400-normal.woff2"],
                            "fontWeight": "400",
                            "fontStyle": "normal",
                            "fontFamily": "Baskervville"
                        },
                        {
                            "src": ["file:./assets/fonts/baskervville/baskervville-500-normal.woff2"],
                            "fontWeight": "500",
                            "fontStyle": "normal",
                            "fontFamily": "Baskervville"
                        },
                        {
                            "src": ["file:./assets/fonts/baskervville/baskervville-600-normal.woff2"],
                            "fontWeight": "600",
                            "fontStyle": "normal",
                            "fontFamily": "Baskervville"
                        },
                        {
                            "src": ["file:./assets/fonts/baskervville/baskervville-700-normal.woff2"],
                            "fontWeight": "700",
                            "fontStyle": "normal",
                            "fontFamily": "Baskervville"
                        },
                        {
                            "src": ["file:./assets/fonts/baskervville/baskervville-400-italic.woff2"],
                            "fontWeight": "400",
                            "fontStyle": "italic",
                            "fontFamily": "Baskervville"
                        },
                        {
                            "src": ["file:./assets/fonts/baskervville/baskervville-500-italic.woff2"],
                            "fontWeight": "500",
                            "fontStyle": "italic",
                            "fontFamily": "Baskervville"
                        },
                        {
                            "src": ["file:./assets/fonts/baskervville/baskervville-600-italic.woff2"],
                            "fontWeight": "600",
                            "fontStyle": "italic",
                            "fontFamily": "Baskervville"
                        },
                        {
                            "src": ["file:./assets/fonts/baskervville/baskervville-700-italic.woff2"],
                            "fontWeight": "700",
                            "fontStyle": "italic",
                            "fontFamily": "Baskervville"
                        }
                    ]
                }
            ],
            "fontSizes": [
                {
                    "fluid": false,
                    "name": "Tiny",
                    "size": "0.75rem",
                    "slug": "blnt-tiny"
                },
                {
                    "fluid": false,
                    "name": "Small",
                    "size": "0.875rem",
                    "slug": "blnt-small"
                },
                {
                    "fluid": false,
                    "name": "Regular",
                    "size": "1rem",
                    "slug": "blnt-regular"
                },
                {
                    "fluid": false,
                    "name": "Medium",
                    "size": "1.125rem",
                    "slug": "blnt-medium"
                },
                {
                    "fluid": {
                        "max": "1.375rem",
                        "min": "1.125rem"
                    },
                    "name": "Large",
                    "size": "1.375rem",
                    "slug": "blnt-large"
                },
                {
                    "fluid": {
                        "max": "1.75rem",
                        "min": "1.25rem"
                    },
                    "name": "X Large",
                    "size": "1.75rem",
                    "slug": "blnt-x-large"
                },
                {
                    "fluid": {
                        "max": "2.25rem",
                        "min": "1.5rem"
                    },
                    "name": "XX Large",
                    "size": "2.15rem",
                    "slug": "blnt-xx-large"
                },
                {
                    "fluid": {
                        "max": "2.75rem",
                        "min": "2rem"
                    },
                    "name": "XXX Large",
                    "size": "2.75rem",
                    "slug": "blnt-xxx-large"
                },
                {
                    "fluid": {
                        "max": "3.25rem",
                        "min": "2.5rem"
                    },
                    "name": "XXXX Large",
                    "size": "3.25rem",
                    "slug": "blnt-xxxx-large"
                },
                {
                    "fluid": {
                        "max": "4.5rem",
                        "min": "2.75rem"
                    },
                    "name": "Huge",
                    "size": "4.5rem",
                    "slug": "blnt-huge"
                }
            ],
            "writingMode": true
        },
        "useRootPaddingAwareAlignments": true
    },
    "styles": {
        "blocks": {
            "core/avatar": {
                "border": {
                    "radius": "100px"
                }
            },
            "core/button": {
                "variations": {
                    "link": {
                        "border": {
                            "color": "transparent",
                            "radius": "0",
                            "width": "0"
                        },
                        "color": {
                            "background": "transparent",
                            "text": "var(--wp--preset--color--blnt-red)"
                        },
                        "css": "&::after { content: ''; display: inline-block; width: 7px; height: 7px; border-top: 2px solid currentColor; border-right: 2px solid currentColor; transform: rotate(45deg); margin-left: 10px; vertical-align: middle; position: relative; top: -1px; } &:hover { background: transparent; color: var(--wp--preset--color--blnt-black); text-decoration: none; border-color: transparent; }",
                        "spacing": {
                            "padding": {
                                "bottom": "0",
                                "left": "0",
                                "right": "0",
                                "top": "0"
                            }
                        }
                    },
                    "arrow-link": {
                        "border": {
                            "color": "transparent",
                            "radius": "0",
                            "width": "0"
                        },
                        "color": {
                            "background": "transparent",
                            "text": "var(--wp--preset--color--blnt-black)"
                        },
                        "css": "&::after { content: ''; display: inline-block; width: 16px; height: 16px; margin-left: 10px; vertical-align: middle; background-color: currentColor; -webkit-mask-image: url(\"data:image/svg+xml,%3Csvg width='16' height='16' viewBox='0 0 16 16' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M8.145.5c.07 0 .132.017.194.06L8.4.614l6.949 6.949a.4.4 0 0 1 .09.125.3.3 0 0 1 .024.125.3.3 0 0 1-.023.122.4.4 0 0 1-.091.126l-6.954 6.948c-.092.09-.17.116-.253.116-.081 0-.153-.025-.237-.11L7.9 15.01l-.051-.06a.3.3 0 0 1-.057-.183c0-.065.015-.123.057-.182l.051-.06 6.362-6.362H.852c-.123 0-.195-.035-.255-.096H.596C.535 8.006.5 7.933.5 7.811s.035-.195.096-.256a.33.33 0 0 1 .256-.096h13.41L7.906 1.104a.35.35 0 0 1-.105-.185L7.795.852A.32.32 0 0 1 7.9.607h.001A.31.31 0 0 1 8.145.5Z' fill='%23000' stroke='%23000'/%3E%3C/svg%3E\"); mask-image: url(\"data:image/svg+xml,%3Csvg width='16' height='16' viewBox='0 0 16 16' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M8.145.5c.07 0 .132.017.194.06L8.4.614l6.949 6.949a.4.4 0 0 1 .09.125.3.3 0 0 1 .024.125.3.3 0 0 1-.023.122.4.4 0 0 1-.091.126l-6.954 6.948c-.092.09-.17.116-.253.116-.081 0-.153-.025-.237-.11L7.9 15.01l-.051-.06a.3.3 0 0 1-.057-.183c0-.065.015-.123.057-.182l.051-.06 6.362-6.362H.852c-.123 0-.195-.035-.255-.096H.596C.535 8.006.5 7.933.5 7.811s.035-.195.096-.256a.33.33 0 0 1 .256-.096h13.41L7.906 1.104a.35.35 0 0 1-.105-.185L7.795.852A.32.32 0 0 1 7.9.607h.001A.31.31 0 0 1 8.145.5Z' fill='%23000' stroke='%23000'/%3E%3C/svg%3E\"); -webkit-mask-size: contain; mask-size: contain; -webkit-mask-repeat: no-repeat; mask-repeat: no-repeat; -webkit-mask-position: center; mask-position: center; position: relative; top: -1px; transition: transform 0.2s ease; } &:hover { background: transparent; color: var(--wp--preset--color--blnt-red); text-decoration: none; border-color: transparent; }",
                        "spacing": {
                            "padding": {
                                "bottom": "0",
                                "left": "0",
                                "right": "0",
                                "top": "0"
                            }
                        }
                    },
                    "outline": {
                        "border": {
                            "color": "var(--wp--preset--color--blnt-red)",
                            "width": "1px"
                        },
                        "color": {
                            "background": "var(--wp--preset--color--blnt-white)",
                            "text": "var(--wp--preset--color--blnt-red)"
                        },
                        "css": ".wp-block-button__link:not(.has-background):hover {background-color:var(--wp--preset--color--blnt-red);color:var(--wp--preset--color--blnt-white);}",
                        "spacing": {
                            "padding": {
                                "bottom": "12px",
                                "left": "24px",
                                "right": "24px",
                                "top": "12px"
                            }
                        }
                    }
                }
            },
            "core/buttons": {
                "spacing": {
                    "blockGap": "16px"
                }
            },
            "core/code": {
                "color": {
                    "background": "var(--wp--preset--color--accent-5)",
                    "text": "var(--wp--preset--color--blnt-black)"
                },
                "spacing": {
                    "padding": {
                        "bottom": "var(--wp--preset--spacing--blnt-40)",
                        "left": "var(--wp--preset--spacing--blnt-40)",
                        "right": "var(--wp--preset--spacing--blnt-40)",
                        "top": "var(--wp--preset--spacing--blnt-40)"
                    }
                },
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--fira-code)",
                    "fontSize": "var(--wp--preset--font-size--blnt-medium)",
                    "fontWeight": "300"
                }
            },
            "core/columns": {
                "spacing": {
                    "blockGap": "var(--wp--preset--spacing--blnt-50)"
                }
            },
            "core/comment-author-name": {
                "color": {
                    "text": "var(--wp--preset--color--accent-4)"
                },
                "elements": {
                    "link": {
                        ":hover": {
                            "typography": {
                                "textDecoration": "underline"
                            }
                        },
                        "color": {
                            "text": "var(--wp--preset--color--accent-4)"
                        },
                        "typography": {
                            "textDecoration": "none"
                        }
                    }
                },
                "spacing": {
                    "margin": {
                        "bottom": "0px",
                        "top": "5px"
                    }
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--blnt-small)"
                }
            },
            "core/comment-content": {
                "spacing": {
                    "margin": {
                        "bottom": "var(--wp--preset--spacing--blnt-30)",
                        "top": "var(--wp--preset--spacing--blnt-30)"
                    }
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--blnt-medium)"
                }
            },
            "core/comment-date": {
                "color": {
                    "text": "var(--wp--preset--color--blnt-black)"
                },
                "elements": {
                    "link": {
                        "color": {
                            "text": "var(--wp--preset--color--blnt-black)"
                        }
                    }
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--blnt-small)"
                }
            },
            "core/comment-edit-link": {
                "elements": {
                    "link": {
                        "color": {
                            "text": "var(--wp--preset--color--blnt-black)"
                        }
                    }
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--blnt-small)"
                }
            },
            "core/comment-reply-link": {
                "elements": {
                    "link": {
                        "color": {
                            "text": "var(--wp--preset--color--blnt-black)"
                        }
                    }
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--blnt-small)"
                }
            },
            "core/comments-pagination": {
                "spacing": {
                    "margin": {
                        "bottom": "var(--wp--preset--spacing--blnt-40)",
                        "top": "var(--wp--preset--spacing--blnt-40)"
                    }
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--blnt-medium)"
                }
            },
            "core/comments-pagination-next": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--blnt-medium)"
                }
            },
            "core/comments-pagination-numbers": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--blnt-medium)"
                }
            },
            "core/comments-pagination-previous": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--blnt-medium)"
                }
            },
            "core/list": {
                "css": "& li{margin-top: 0.5rem;}"
            },
            "core/navigation": {
                "elements": {
                    "link": {
                        ":hover": {
                            "typography": {
                                "textDecoration": "underline"
                            }
                        },
                        "typography": {
                            "textDecoration": "none"
                        }
                    }
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--blnt-medium)"
                }
            },
            "core/post-comments-form": {
                "css": "& textarea, input:not([type=submit]){border-radius:.25rem; border-color: var(--wp--preset--color--accent-6) !important;} & input[type=checkbox]{margin:0 .2rem 0 0 !important;} & label {font-size: var(--wp--preset--font-size--blnt-small); }",
                "spacing": {
                    "padding": {
                        "bottom": "var(--wp--preset--spacing--blnt-40)",
                        "top": "var(--wp--preset--spacing--blnt-40)"
                    }
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--blnt-medium)"
                }
            },
            "core/post-date": {
                "color": {
                    "text": "var(--wp--preset--color--accent-4)"
                },
                "elements": {
                    "link": {
                        ":hover": {
                            "typography": {
                                "textDecoration": "underline"
                            }
                        },
                        "color": {
                            "text": "var(--wp--preset--color--accent-4)"
                        },
                        "typography": {
                            "textDecoration": "none"
                        }
                    }
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--blnt-small)"
                }
            },
            "core/post-navigation-link": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--blnt-medium)"
                }
            },
            "core/post-terms": {
                "css": "& a { white-space: nowrap; }",
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--blnt-small)",
                    "fontWeight": "600"
                }
            },
            "core/post-title": {
                "elements": {
                    "link": {
                        ":hover": {
                            "typography": {
                                "textDecoration": "underline"
                            }
                        },
                        "typography": {
                            "textDecoration": "none",
                            "fontWeight": "400",
                            "lineHeight": "1.2",
                            "fontSize": "var(--wp--preset--font-size--blnt-huge)"
                        }
                    }
                }
            },
            "core/pullquote": {
                "css": "& p:last-of-type {margin-bottom: var(--wp--preset--spacing--blnt-30);}",
                "elements": {
                    "cite": {
                        "typography": {
                            "fontSize": "var(--wp--preset--font-size--blnt-small)",
                            "fontStyle": "normal"
                        }
                    }
                },
                "spacing": {
                    "padding": {
                        "bottom": "var(--wp--preset--spacing--blnt-30)",
                        "top": "var(--wp--preset--spacing--blnt-30)"
                    }
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--blnt-xx-large)",
                    "fontWeight": "300",
                    "lineHeight": "1.2"
                }
            },
            "core/query-pagination": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--blnt-medium)",
                    "fontWeight": "500"
                }
            },
            "core/quote": {
                "border": {
                    "color": "currentColor",
                    "style": "solid",
                    "width": "0 0 0 2px"
                },
                "css": "&.has-text-align-right { border-width: 0 2px 0 0; } &.has-text-align-center { border-width: 0;border-inline: 0; padding-inline: 0; }",
                "elements": {
                    "cite": {
                        "css": "& sub { font-size: 0.65em }",
                        "typography": {
                            "fontSize": "var(--wp--preset--font-size--blnt-small)",
                            "fontStyle": "normal",
                            "fontWeight": "300"
                        }
                    }
                },
                "spacing": {
                    "blockGap": "var(--wp--preset--spacing--blnt-30)",
                    "margin": {
                        "left": "0",
                        "right": "0"
