    "settings": {
        "appearanceTools": true,
        "color": {
            "defaultDuotone": false,
            "defaultGradients": false,
            "defaultPalette": false,
            "gradients": [
                {
                    "gradient": "linear-gradient(159.88deg, rgba(177, 191, 205, 0) 13.41%, #DDE4EB 82.81%)",
                    "name": "Gradient One",
                    "slug": "insa-gradient-one"
                },
                {
                    "gradient": "radial-gradient(164.05% 124.18% at 50% 124.18%, #000000 1.44%, #7A1E2B 10.58%, rgba(0, 0, 0, 0) 55.77%, rgba(0, 0, 0, 0) 100%)",
                    "name": "Gradient Background",
                    "slug": "insa-gradient-background"
                },
                {
                    "gradient": "radial-gradient(104.44% 357.81% at 6.11% 44.67%, rgba(0, 0, 0, 0.8) 45.67%, rgba(122, 30, 43, 0.8) 100%)",
                    "name": "Radial Gradient",
                    "slug": "insa-radial-gradient"
                },
                {
                    "gradient": "radial-gradient(164.05% 124.18% at 50% 124.18%, #000000 1.44%, #7A1E2B 10.58%, rgba(0, 0, 0, 0) 55.77%, rgba(0, 0, 0, 0) 100%)",
                    "name": "Radial Gradient 2",
                    "slug": "insa-radial-gradient-2"
