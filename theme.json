                            "fontWeight": "200",
                            "fontStyle": "italic",
                            "fontFamily": "\"Plus Jakarta Sans\""
                        },
                        {
                            "src": ["file:./assets/fonts/plus-jakarta-sans/plus-jakarta-sans-300-italic.woff2"],
                            "fontWeight": "300",
                            "fontStyle": "italic",
                            "fontFamily": "\"Plus Jakarta Sans\""
                        },
                        {
                            "src": ["file:./assets/fonts/plus-jakarta-sans/plus-jakarta-sans-400-italic.woff2"],
