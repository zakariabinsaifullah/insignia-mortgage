                            "fontFamily": "\"Plus Jakarta Sans\""
                        },
                        {
                            "src": ["file:./assets/fonts/plus-jakarta-sans/plus-jakarta-sans-500-italic.woff2"],
                            "fontWeight": "500",
                            "fontStyle": "italic",
                            "fontFamily": "\"Plus Jakarta Sans\""
                        },
                        {
                            "src": ["file:./assets/fonts/plus-jakarta-sans/plus-jakarta-sans-600-italic.woff2"],
                            "fontWeight": "600",
                            "fontStyle": "italic",
                            "fontFamily": "\"Plus Jakarta Sans\""
                        },
                        {
                            "src": ["file:./assets/fonts/plus-jakarta-sans/plus-jakarta-sans-700-italic.woff2"],
                            "fontWeight": "700",
                            "fontStyle": "italic",
                            "fontFamily": "\"Plus Jakarta Sans\""
                        }
                    ]
                }
            ],
            "fontSizes": [
                {
                    "fluid": false,
                    "name": "Small",
                    "size": "12px",
                    "slug": "insa-small"
                },
                {
                    "fluid": false,
                    "name": "Normal",
                    "size": "14px",
                    "slug": "insa-normal"
                },
                {
                    "fluid": false,
                    "name": "Button",
                    "size": "16px",
                    "slug": "insa-button"
                },
                {
                    "fluid": {
                        "max": "24px",
                        "min": "22px"
                    },
                    "name": "H6",
                    "size": "24px",
                    "slug": "insa-heading-six"
                },
                {
                    "fluid": {
                        "max": "32px",
                        "min": "26px"
                    },
                    "name": "H5",
                    "size": "32px",
                    "slug": "insa-heading-five"
                },
                {
                    "fluid": {
                        "max": "36px",
                        "min": "30px"
                    },
                    "name": "H4",
                    "size": "36px",
                    "slug": "insa-heading-four"
                },
                {
                    "fluid": {
                        "max": "42px",
                        "min": "36px"
                    },
                    "name": "H3",
                    "size": "42px",
                    "slug": "insa-heading-three"
                },
                {
                    "fluid": {
                        "max": "50px",
                        "min": "40px"
                    },
                    "name": "H2",
                    "size": "50px",
                    "slug": "insa-heading-two"
                },
                {
                    "fluid": {
                        "max": "56px",
                        "min": "44px"
                    },
                    "name": "H1",
                    "size": "56px",
                    "slug": "insa-heading-one"
                },
                {
                    "fluid": {
                        "max": "56px",
                        "min": "28px"
                    },
                    "name": "Title",
                    "size": "56px",
                    "slug": "insa-title"
                },
                {
                    "fluid": {
                        "max": "80px",
                        "min": "56px"
                    },
                    "name": "Display",
                    "size": "80px",
                    "slug": "insa-display"
                }
            ],
            "writingMode": true
        },
        "useRootPaddingAwareAlignments": true,
        "shadow": {
            "defaultPresets": false,
            "presets": [
                {
                    "name": "Light Dark",
                    "slug": "insa-light-dark",
                    "shadow": "0px 5px 15px rgba(0, 0, 0, 0.4)"
                }
            ]
        }
    },
    "styles": {
        "blocks": {
            "core/avatar": {
                "border": {
                    "radius": "100px"
                }
            },
            "core/button": {
                "variations": {
                    "link": {
                        "border": {
                            "color": "transparent",
                            "radius": "0",
                            "width": "0"
                        },
                        "color": {
                            "background": "transparent",
                            "text": "var(--wp--preset--color--insa-downriver)"
                        },
                        "css": "&::after { content: ''; display: inline-block; width: 16px; height: 14px; margin-left: 8px; vertical-align: middle; background-color: #5C8C1F; -webkit-mask-image: url(\"data:image/svg+xml,%3Csvg width='16' height='14' viewBox='0 0 16 14' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M15.4688 7.45312L9.28125 13.3594C8.92969 13.6758 8.40234 13.6758 8.08594 13.3242C7.76953 12.9727 7.76953 12.4453 8.12109 12.1289L12.7969 7.66406H0.84375C0.351562 7.66406 0 7.3125 0 6.82031C0 6.36328 0.351562 5.97656 0.84375 5.97656H12.7969L8.12109 1.54688C7.76953 1.23047 7.76953 0.667969 8.08594 0.351562C8.40234 0 8.96484 0 9.28125 0.316406L15.4688 6.22266C15.6445 6.39844 15.75 6.60938 15.75 6.82031C15.75 7.06641 15.6445 7.27734 15.4688 7.45312Z' fill='%23000'/%3E%3C/svg%3E\"); mask-image: url(\"data:image/svg+xml,%3Csvg width='16' height='14' viewBox='0 0 16 14' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M15.4688 7.45312L9.28125 13.3594C8.92969 13.6758 8.40234 13.6758 8.08594 13.3242C7.76953 12.9727 7.76953 12.4453 8.12109 12.1289L12.7969 7.66406H0.84375C0.351562 7.66406 0 7.3125 0 6.82031C0 6.36328 0.351562 5.97656 0.84375 5.97656H12.7969L8.12109 1.54688C7.76953 1.23047 7.76953 0.667969 8.08594 0.351562C8.40234 0 8.96484 0 9.28125 0.316406L15.4688 6.22266C15.6445 6.39844 15.75 6.60938 15.75 6.82031C15.75 7.06641 15.6445 7.27734 15.4688 7.45312Z' fill='%23000'/%3E%3C/svg%3E\"); -webkit-mask-size: contain; mask-size: contain; -webkit-mask-repeat: no-repeat; mask-repeat: no-repeat; -webkit-mask-position: center; mask-position: center; position: relative; top: -1px; transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1); }",
                        "spacing": {
                            "padding": {
                                "bottom": "0",
                                "left": "0",
                                "right": "0",
                                "top": "0"
                            }
                        }
                    },
                    "outline": {
                        "border": {
                            "color": "currentColor",
                            "width": "1px"
                        },
                        "color": {
                            "background": "transparent",
                            "text": "var(--wp--preset--color--insa-downriver)"
                        },
                        "css": ".wp-block-button__link:not(.has-background):hover {background-color:var(--wp--preset--color--insa-downriver);color:var(--wp--preset--color--insa-white);}",
                        "spacing": {
                            "padding": {
                                "bottom": "12px",
                                "left": "24px",
                                "right": "24px",
                                "top": "12px"
                            }
                        }
                    }
                }
            },
            "core/buttons": {
                "spacing": {
                    "blockGap": "16px"
                }
            },
            "core/code": {
                "color": {
                    "background": "var(--wp--preset--color--accent-5)",
                    "text": "var(--wp--preset--color--insa-black)"
                },
                "spacing": {
                    "padding": {
                        "bottom": "var(--wp--preset--spacing--insa-40)",
                        "left": "var(--wp--preset--spacing--insa-40)",
                        "right": "var(--wp--preset--spacing--insa-40)",
                        "top": "var(--wp--preset--spacing--insa-40)"
                    }
                },
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--fira-code)",
                    "fontSize": "var(--wp--preset--font-size--insa-normal)",
                    "fontWeight": "400"
                }
            },
            "core/columns": {
                "spacing": {
                    "blockGap": "var(--wp--preset--spacing--insa-50)"
                }
            },
            "core/comment-author-name": {
                "color": {
                    "text": "var(--wp--preset--color--accent-4)"
                },
                "elements": {
                    "link": {
                        ":hover": {
                            "typography": {
                                "textDecoration": "underline"
                            }
                        },
                        "color": {
                            "text": "var(--wp--preset--color--accent-4)"
                        },
                        "typography": {
                            "textDecoration": "none"
                        }
                    }
                },
                "spacing": {
                    "margin": {
                        "bottom": "0px",
                        "top": "5px"
                    }
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--insa-small)"
                }
            },
            "core/comment-content": {
                "spacing": {
                    "margin": {
                        "bottom": "var(--wp--preset--spacing--insa-30)",
                        "top": "var(--wp--preset--spacing--insa-30)"
                    }
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--insa-normal)"
                }
            },
            "core/comment-date": {
                "color": {
                    "text": "var(--wp--preset--color--insa-black)"
                },
                "elements": {
                    "link": {
                        "color": {
                            "text": "var(--wp--preset--color--insa-black)"
                        }
                    }
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--insa-small)"
                }
            },
            "core/comment-edit-link": {
                "elements": {
                    "link": {
                        "color": {
                            "text": "var(--wp--preset--color--insa-black)"
                        }
                    }
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--insa-small)"
                }
            },
            "core/comment-reply-link": {
                "elements": {
                    "link": {
                        "color": {
                            "text": "var(--wp--preset--color--insa-black)"
                        }
                    }
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--insa-small)"
                }
            },
            "core/comments-pagination": {
                "spacing": {
                    "margin": {
                        "bottom": "var(--wp--preset--spacing--insa-40)",
                        "top": "var(--wp--preset--spacing--insa-40)"
                    }
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--insa-normal)"
                }
            },
            "core/comments-pagination-next": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--insa-normal)"
                }
            },
            "core/comments-pagination-numbers": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--insa-normal)"
                }
            },
            "core/comments-pagination-previous": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--insa-normal)"
                }
            },
            "core/list": {
                "css": "& li{margin-top: 0.5rem;}"
            },
            "core/navigation": {
                "elements": {
                    "link": {
                        ":hover": {
                            "typography": {
                                "textDecoration": "underline"
                            }
                        },
                        "typography": {
                            "textDecoration": "none"
                        }
                    }
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--insa-normal)"
                }
            },
            "core/post-comments-form": {
                "css": "& textarea, input:not([type=submit]){border-radius:.25rem; border-color: var(--wp--preset--color--accent-6) !important;} & input[type=checkbox]{margin:0 .2rem 0 0 !important;} & label {font-size: var(--wp--preset--font-size--insa-small); }",
                "spacing": {
                    "padding": {
                        "bottom": "var(--wp--preset--spacing--insa-40)",
                        "top": "var(--wp--preset--spacing--insa-40)"
                    }
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--insa-normal)"
                }
            },
            "core/post-date": {
                "color": {
                    "text": "var(--wp--preset--color--accent-4)"
                },
                "elements": {
                    "link": {
                        ":hover": {
                            "typography": {
                                "textDecoration": "underline"
                            }
                        },
                        "color": {
                            "text": "var(--wp--preset--color--accent-4)"
                        },
                        "typography": {
                            "textDecoration": "none"
                        }
                    }
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--insa-small)"
                }
            },
            "core/post-navigation-link": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--insa-normal)"
                }
            },
            "core/post-terms": {
                "css": "& a { white-space: nowrap; }",
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--insa-small)",
                    "fontWeight": "600"
                }
            },
            "core/post-title": {
                "elements": {
                    "link": {
                        ":hover": {
                            "typography": {
                                "textDecoration": "none"
                            }
                        },
                        "typography": {
                            "fontWeight": "400",
                            "lineHeight": "1.2",
                            "textDecoration": "none"
                        }
                    }
                }
            },
            "core/pullquote": {
                "css": "& p:last-of-type {margin-bottom: var(--wp--preset--spacing--insa-30);}",
                "elements": {
                    "cite": {
                        "typography": {
                            "fontSize": "var(--wp--preset--font-size--insa-small)",
                            "fontStyle": "normal"
                        }
                    }
                },
                "spacing": {
                    "padding": {
                        "bottom": "var(--wp--preset--spacing--insa-30)",
                        "top": "var(--wp--preset--spacing--insa-30)"
                    }
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--insa-heading-four)",
                    "fontWeight": "500",
                    "lineHeight": "1.2"
                }
            },
            "core/query-pagination": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--insa-normal)",
                    "fontWeight": "500"
                }
            },
            "core/quote": {
                "border": {
                    "color": "currentColor",
                    "style": "solid",
                    "width": "0 0 0 2px"
                },
                "css": "&.has-text-align-right { border-width: 0 2px 0 0; } &.has-text-align-center { border-width: 0;border-inline: 0; padding-inline: 0; }",
                "elements": {
                    "cite": {
                        "css": "& sub { font-size: 0.65em }",
                        "typography": {
                            "fontSize": "var(--wp--preset--font-size--insa-small)",
                            "fontStyle": "normal",
                            "fontWeight": "400"
                        }
                    }
                },
                "spacing": {
                    "blockGap": "var(--wp--preset--spacing--insa-30)",
                    "margin": {
                        "left": "0",
                        "right": "0"
                    },
                    "padding": {
                        "bottom": "var(--wp--preset--spacing--insa-30)",
                        "left": "var(--wp--preset--spacing--insa-40)",
                        "right": "var(--wp--preset--spacing--insa-40)",
                        "top": "var(--wp--preset--spacing--insa-30)"
                    }
                },
