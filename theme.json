{
    "$schema": "https://schemas.wp.org/wp/6.9/theme.json",
    "version": 3,
    "insaTemplates": [
        {
            "name": "page-no-title",
            "postTypes": [
                "page"
            ],
            "title": "Page No Title"
        }
    ],
    "settings": {
        "appearanceTools": true,
        "color": {
            "defaultDuotone": false,
            "defaultGradients": false,
            "defaultPalette": false,
            "gradients": [
                {
                    "gradient": "linear-gradient(159.88deg, rgba(177, 191, 205, 0) 13.41%, #DDE4EB 82.81%)",
                    "name": "Gradient One",
                    "slug": "insa-gradient-one"
                },
                {
                    "gradient": "radial-gradient(164.05% 124.18% at 50% 124.18%, #000000 1.44%, #7A1E2B 10.58%, rgba(0, 0, 0, 0) 55.77%, rgba(0, 0, 0, 0) 100%)",
                    "name": "Gradient Background",
                    "slug": "insa-gradient-background"
                },
                {
                    "gradient": "radial-gradient(104.44% 357.81% at 6.11% 44.67%, rgba(0, 0, 0, 0.8) 45.67%, rgba(122, 30, 43, 0.8) 100%)",
                    "name": "Radial Gradient",
                    "slug": "insa-radial-gradient"
                },
                {
                    "gradient": "radial-gradient(164.05% 124.18% at 50% 124.18%, #000000 1.44%, #7A1E2B 10.58%, rgba(0, 0, 0, 0) 55.77%, rgba(0, 0, 0, 0) 100%)",
                    "name": "Radial Gradient 2",
                    "slug": "insa-radial-gradient-2"
                },
                {
                    "gradient": "linear-gradient(180deg, #9D272D 6.73%, #6C080A 54%, rgba(221, 66, 66, 0) 100%)",
                    "name": "Linear Gradient",
                    "slug": "insa-linear-gradient"
                },
                {
                    "gradient": "linear-gradient(90.21deg, #191919 44.34%, #7A1E2B 99.76%)",
                    "name": "Linear Gradient 2",
                    "slug": "insa-linear-gradient-2"
                },
                {
                    "gradient": "linear-gradient(180deg, #FFFFFF 0%, #FFFFFF 0%, rgba(221, 66, 66, 0.20) 100%)",
                    "name": "Linear",
                    "slug": "insa-linear"
                }
            ],
            "palette": [
                {
                    "color": "#FFFFFF",
                    "name": "White",
                    "slug": "insa-white"
                },
                {
                    "color": "#f8f8f0",
                    "name": "Off White",
                    "slug": "insa-off-white"
                },
                {
                    "color": "#7f8081",
                    "name": "Light Gray",
                    "slug": "insa-light-gray"
                },
                {
                    "color": "#000000",
                    "name": "Black",
                    "slug": "insa-black"
                },
                {
                    "color": "#00323f",
                    "name": "Cyprus",
                    "slug": "insa-cyprus"
                },
                {
                    "color": "#126464",
                    "name": "Inline Highlight",
                    "slug": "insa-inline-highlight"
                },
                {
                    "color": "#05143e",
                    "name": "Card Bg",
                    "slug": "insa-card-bg"
                },
                {
                    "color": "#000104",
                    "name": "Body Color",
                    "slug": "insa-body-color"
                },
                {
                    "color": "#9dc767",
                    "name": "Olive",
                    "slug": "insa-olive"
                },
                {
                    "color": "#2E460F",
                    "name": "Olive Dark",
                    "slug": "insa-olive-dark"
                },
                {
                    "color": "#002832",
                    "name": "Cyprus Dark",
                    "slug": "insa-cyprus-dark"
                },
                {
                    "color": "#6E300B",
                    "name": "Brown",
                    "slug": "insa-brown"
                },
                {
                    "color": "#071A4E",
                    "name": "Navy",
                    "slug": "insa-navy"
                },
                {
                    "color": "#461C44",
                    "name": "Dark Plum",
                    "slug": "insa-dark-plum"
                }
            ]
        },
        "layout": {
            "contentSize": "1280px",
            "wideSize": "1440px"
        },
        "spacing": {
            "defaultSpacingSizes": false,
            "spacingSizes": [
                {
                    "name": "Edge Gap",
                    "size": "1rem",
                    "slug": "insa-edge-gap"
                },
                {
                    "name": "Elements Gap",
                    "size": "1.5rem",
                    "slug": "insa-elements-gap"
                },
                {
                    "name": "Small",
                    "size": "30px",
                    "slug": "insa-30"
                },
                {
                    "name": "Regular",
                    "size": "clamp(30px, 5vw, 50px)",
                    "slug": "insa-50"
                },
                {
                    "name": "Large",
                    "size": "clamp(30px, 7vw, 70px)",
                    "slug": "insa-60"
                },
                {
                    "name": "X-Large",
                    "size": "clamp(70px, 7vw, 100px)",
                    "slug": "insa-100"
                },
                {
                    "name": "Section Padding",
                    "size": "clamp(70px, 10vw, 100px)",
                    "slug": "insa-section-padding"
                }
            ],
            "units": [
                "%",
                "px",
                "em",
                "rem",
                "vh",
                "vw"
            ]
        },
        "typography": {
            "defaultFontSizes": false,
            "fluid": true,
            "fontFamilies": [
                {
                    "name": "Plus Jakarta Sans",
                    "slug": "plus-jakarta-sans",
                    "fontFamily": "\"Plus Jakarta Sans\", sans-serif",
                    "fontFace": [
                        {
                            "src": [
                                "file:./assets/fonts/plus-jakarta-sans/plus-jakarta-sans-200-normal.woff2"
                            ],
                            "fontWeight": "200",
                            "fontStyle": "normal",
                            "fontFamily": "\"Plus Jakarta Sans\""
                        },
                        {
                            "src": [
                                "file:./assets/fonts/plus-jakarta-sans/plus-jakarta-sans-300-normal.woff2"
                            ],
                            "fontWeight": "300",
                            "fontStyle": "normal",
                            "fontFamily": "\"Plus Jakarta Sans\""
                        },
                        {
                            "src": [
                                "file:./assets/fonts/plus-jakarta-sans/plus-jakarta-sans-400-normal.woff2"
                            ],
                            "fontWeight": "400",
                            "fontStyle": "normal",
                            "fontFamily": "\"Plus Jakarta Sans\""
                        },
                        {
                            "src": [
                                "file:./assets/fonts/plus-jakarta-sans/plus-jakarta-sans-500-normal.woff2"
                            ],
                            "fontWeight": "500",
                            "fontStyle": "normal",
                            "fontFamily": "\"Plus Jakarta Sans\""
                        },
                        {
                            "src": [
                                "file:./assets/fonts/plus-jakarta-sans/plus-jakarta-sans-600-normal.woff2"
                            ],
                            "fontWeight": "600",
                            "fontStyle": "normal",
                            "fontFamily": "\"Plus Jakarta Sans\""
                        },
                        {
                            "src": [
                                "file:./assets/fonts/plus-jakarta-sans/plus-jakarta-sans-700-normal.woff2"
                            ],
                            "fontWeight": "700",
                            "fontStyle": "normal",
                            "fontFamily": "\"Plus Jakarta Sans\""
                        },
                        {
                            "src": [
                                "file:./assets/fonts/plus-jakarta-sans/plus-jakarta-sans-200-italic.woff2"
                            ],
                            "fontWeight": "200",
                            "fontStyle": "italic",
                            "fontFamily": "\"Plus Jakarta Sans\""
                        },
                        {
                            "src": [
                                "file:./assets/fonts/plus-jakarta-sans/plus-jakarta-sans-300-italic.woff2"
                            ],
                            "fontWeight": "300",
                            "fontStyle": "italic",
                            "fontFamily": "\"Plus Jakarta Sans\""
                        },
                        {
                            "src": [
                                "file:./assets/fonts/plus-jakarta-sans/plus-jakarta-sans-400-italic.woff2"
                            ],
                            "fontWeight": "400",
                            "fontStyle": "italic",
                            "fontFamily": "\"Plus Jakarta Sans\""
                        },
                        {
                            "src": [
                                "file:./assets/fonts/plus-jakarta-sans/plus-jakarta-sans-500-italic.woff2"
                            ],
                            "fontWeight": "500",
                            "fontStyle": "italic",
                            "fontFamily": "\"Plus Jakarta Sans\""
                        },
                        {
                            "src": [
                                "file:./assets/fonts/plus-jakarta-sans/plus-jakarta-sans-600-italic.woff2"
                            ],
                            "fontWeight": "600",
                            "fontStyle": "italic",
                            "fontFamily": "\"Plus Jakarta Sans\""
                        },
                        {
                            "src": [
                                "file:./assets/fonts/plus-jakarta-sans/plus-jakarta-sans-700-italic.woff2"
                            ],
                            "fontWeight": "700",
                            "fontStyle": "italic",
                            "fontFamily": "\"Plus Jakarta Sans\""
                        }
                    ]
                }
            ],
            "fontSizes": [
                {
                    "fluid": false,
                    "name": "Tiny",
                    "size": "0.75rem",
                    "slug": "insa-tiny"
                },
                {
                    "fluid": false,
                    "name": "Small",
                    "size": "0.88rem",
                    "slug": "insa-small"
                },
                {
                    "fluid": false,
                    "name": "Regular",
                    "size": "1rem",
                    "slug": "insa-regular"
                },
                {
                    "fluid": false,
                    "name": "Medium",
                    "size": "1.125rem",
                    "slug": "insa-medium"
                },
                {
                    "fluid": {
                        "max": "1.5rem",
                        "min": "1.125rem"
                    },
                    "name": "Large",
                    "size": "1.375rem",
                    "slug": "insa-large"
                },
                {
                    "fluid": {
                        "max": "2rem",
                        "min": "1.25rem"
                    },
                    "name": "X Large",
                    "size": "1.75rem",
                    "slug": "insa-x-large"
                },
                {
                    "fluid": {
                        "max": "2.25rem",
                        "min": "1.5rem"
                    },
                    "name": "XX Large",
                    "size": "2.15rem",
                    "slug": "insa-xx-large"
                },
                {
                    "fluid": {
                        "max": "3rem",
                        "min": "2rem"
                    },
                    "name": "XXX Large",
                    "size": "2.75rem",
                    "slug": "insa-xxx-large"
                },
                {
                    "fluid": {
                        "max": "3.75rem",
                        "min": "2.75rem"
                    },
                    "name": "XXXX Large",
                    "size": "3.25rem",
                    "slug": "insa-xxxx-large"
                },
                {
                    "fluid": {
                        "max": "4.1rem",
                        "min": "3rem"
                    },
                    "name": "Huge",
                    "size": "4.5rem",
                    "slug": "insa-huge"
                },
                {
                    "fluid": {
                        "max": "127px",
                        "min": "72px"
                    },
                    "name": "Super Title",
                    "size": "127px",
                    "slug": "insa-super-title"
                }
            ],
            "writingMode": true
        },
        "useRootPaddingAwareAlignments": true
    },
    "styles": {
        "blocks": {
            "core/avatar": {
                "border": {
                    "radius": "100px"
                }
            },
            "core/button": {
                "variations": {
                    "arrow-link": {
                        "border": {
                            "color": "transparent",
                            "radius": "0",
                            "width": "0"
                        },
                        "color": {
                            "background": "transparent",
                            "text": "var(--wp--preset--color--insa-black)"
                        },
                        "css": "&::after { content: ''; display: inline-block; width: 16px; height: 16px; margin-left: 10px; vertical-align: middle; background-color: currentColor; -webkit-mask-image: url(\"data:image/svg+xml,%3Csvg width='16' height='16' viewBox='0 0 16 16' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M8.145.5c.07 0 .132.017.194.06L8.4.614l6.949 6.949a.4.4 0 0 1 .09.125.3.3 0 0 1 .024.125.3.3 0 0 1-.023.122.4.4 0 0 1-.091.126l-6.954 6.948c-.092.09-.17.116-.253.116-.081 0-.153-.025-.237-.11L7.9 15.01l-.051-.06a.3.3 0 0 1-.057-.183c0-.065.015-.123.057-.182l.051-.06 6.362-6.362H.852c-.123 0-.195-.035-.255-.096H.596C.535 8.006.5 7.933.5 7.811s.035-.195.096-.256a.33.33 0 0 1 .256-.096h13.41L7.906 1.104a.35.35 0 0 1-.105-.185L7.795.852A.32.32 0 0 1 7.9.607h.001A.31.31 0 0 1 8.145.5Z' fill='%23000' stroke='%23000'/%3E%3C/svg%3E\"); mask-image: url(\"data:image/svg+xml,%3Csvg width='16' height='16' viewBox='0 0 16 16' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M8.145.5c.07 0 .132.017.194.06L8.4.614l6.949 6.949a.4.4 0 0 1 .09.125.3.3 0 0 1 .024.125.3.3 0 0 1-.023.122.4.4 0 0 1-.091.126l-6.954 6.948c-.092.09-.17.116-.253.116-.081 0-.153-.025-.237-.11L7.9 15.01l-.051-.06a.3.3 0 0 1-.057-.183c0-.065.015-.123.057-.182l.051-.06 6.362-6.362H.852c-.123 0-.195-.035-.255-.096H.596C.535 8.006.5 7.933.5 7.811s.035-.195.096-.256a.33.33 0 0 1 .256-.096h13.41L7.906 1.104a.35.35 0 0 1-.105-.185L7.795.852A.32.32 0 0 1 7.9.607h.001A.31.31 0 0 1 8.145.5Z' fill='%23000' stroke='%23000'/%3E%3C/svg%3E\"); -webkit-mask-size: contain; mask-size: contain; -webkit-mask-repeat: no-repeat; mask-repeat: no-repeat; -webkit-mask-position: center; mask-position: center; position: relative; top: -1px; transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1); } &:hover { background: transparent; color: var(--wp--preset--color--insa-cyprus); text-decoration: none; border-color: transparent; }",
                        "spacing": {
                            "padding": {
                                "bottom": "0",
                                "left": "0",
                                "right": "0",
                                "top": "0"
                            }
                        }
                    },
                    "link": {
                        "border": {
                            "color": "transparent",
                            "radius": "0",
                            "width": "0"
                        },
                        "color": {
                            "background": "transparent",
                            "text": "var(--wp--preset--color--insa-cyprus)"
                        },
                        "css": "&::after { content: ''; display: inline-block; width: 7px; height: 7px; border-top: 2px solid currentColor; border-right: 2px solid currentColor; transform: rotate(45deg); margin-left: 10px; vertical-align: middle; position: relative; top: -1px; } &:hover { background: transparent; color: var(--wp--preset--color--insa-black); text-decoration: none; border-color: transparent; }",
                        "spacing": {
                            "padding": {
                                "bottom": "0",
                                "left": "0",
                                "right": "0",
                                "top": "0"
                            }
                        }
                    },
                    "outline": {
                        "border": {
                            "color": "var(--wp--preset--color--insa-cyprus)",
                            "width": "1px"
                        },
                        "color": {
                            "background": "transparent",
                            "text": "var(--wp--preset--color--insa-cyprus)"
                        },
                        "css": ".wp-block-button__link:not(.has-background):hover {background-color:var(--wp--preset--color--insa-cyprus);color:var(--wp--preset--color--insa-white);}",
                        "spacing": {
                            "padding": {
                                "bottom": "10px",
                                "left": "15px",
                                "right": "15px",
                                "top": "10px"
                            }
                        }
                    }
                }
            },
            "core/buttons": {
                "spacing": {
                    "blockGap": "16px"
                }
            },
            "core/code": {
                "color": {
                    "background": "var(--wp--preset--color--accent-5)",
                    "text": "var(--wp--preset--color--insa-black)"
                },
                "spacing": {
                    "padding": {
                        "bottom": "var(--wp--preset--spacing--insa-40)",
                        "left": "var(--wp--preset--spacing--insa-40)",
                        "right": "var(--wp--preset--spacing--insa-40)",
                        "top": "var(--wp--preset--spacing--insa-40)"
                    }
                },
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--fira-code)",
                    "fontSize": "var(--wp--preset--font-size--insa-medium)",
                    "fontWeight": "300"
                }
            },
            "core/columns": {
                "spacing": {
                    "blockGap": "var(--wp--preset--spacing--insa-50)"
                }
            },
            "core/comment-author-name": {
                "color": {
                    "text": "var(--wp--preset--color--accent-4)"
                },
                "elements": {
                    "link": {
                        ":hover": {
                            "typography": {
                                "textDecoration": "underline"
                            }
                        },
                        "color": {
                            "text": "var(--wp--preset--color--accent-4)"
                        },
                        "typography": {
                            "textDecoration": "none"
                        }
                    }
                },
                "spacing": {
                    "margin": {
                        "bottom": "0px",
                        "top": "5px"
                    }
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--insa-small)"
                }
            },
            "core/comment-content": {
                "spacing": {
                    "margin": {
                        "bottom": "var(--wp--preset--spacing--insa-30)",
                        "top": "var(--wp--preset--spacing--insa-30)"
                    }
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--insa-medium)"
                }
            },
            "core/comment-date": {
                "color": {
                    "text": "var(--wp--preset--color--insa-black)"
                },
                "elements": {
                    "link": {
                        "color": {
                            "text": "var(--wp--preset--color--insa-black)"
                        }
                    }
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--insa-small)"
                }
            },
            "core/comment-edit-link": {
                "elements": {
                    "link": {
                        "color": {
                            "text": "var(--wp--preset--color--insa-black)"
                        }
                    }
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--insa-small)"
                }
            },
            "core/comment-reply-link": {
                "elements": {
                    "link": {
                        "color": {
                            "text": "var(--wp--preset--color--insa-black)"
                        }
                    }
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--insa-small)"
                }
            },
            "core/comments-pagination": {
                "spacing": {
                    "margin": {
                        "bottom": "var(--wp--preset--spacing--insa-40)",
                        "top": "var(--wp--preset--spacing--insa-40)"
                    }
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--insa-medium)"
                }
            },
            "core/comments-pagination-next": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--insa-medium)"
                }
            },
            "core/comments-pagination-numbers": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--insa-medium)"
                }
            },
            "core/comments-pagination-previous": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--insa-medium)"
                }
            },
            "core/list": {
                "css": "& li{margin-top: 0.5rem;}"
            },
            "core/navigation": {
                "elements": {
                    "link": {
                        ":hover": {
                            "typography": {
                                "textDecoration": "underline"
                            }
                        },
                        "typography": {
                            "textDecoration": "none"
                        }
                    }
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--insa-medium)"
                }
            },
            "core/post-comments-form": {
                "css": "& textarea, input:not([type=submit]){border-radius:.25rem; border-color: var(--wp--preset--color--accent-6) !important;} & input[type=checkbox]{margin:0 .2rem 0 0 !important;} & label {font-size: var(--wp--preset--font-size--insa-small); }",
                "spacing": {
                    "padding": {
                        "bottom": "var(--wp--preset--spacing--insa-40)",
                        "top": "var(--wp--preset--spacing--insa-40)"
                    }
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--insa-medium)"
                }
            },
            "core/post-date": {
                "color": {
                    "text": "var(--wp--preset--color--accent-4)"
                },
                "elements": {
                    "link": {
                        ":hover": {
                            "typography": {
                                "textDecoration": "underline"
                            }
                        },
                        "color": {
                            "text": "var(--wp--preset--color--accent-4)"
                        },
                        "typography": {
                            "textDecoration": "none"
                        }
                    }
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--insa-small)"
                }
            },
            "core/post-navigation-link": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--insa-medium)"
                }
            },
            "core/post-terms": {
                "css": "& a { white-space: nowrap; }",
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--insa-small)",
                    "fontWeight": "600"
                }
            },
            "core/post-title": {
                "elements": {
                    "link": {
                        ":hover": {
                            "typography": {
                                "textDecoration": "underline"
                            }
                        },
                        "typography": {
                            "fontSize": "var(--wp--preset--font-size--insa-huge)",
                            "fontWeight": "400",
                            "lineHeight": "1.2",
                            "textDecoration": "none"
                        }
                    }
                }
            },
            "core/pullquote": {
                "css": "& p:last-of-type {margin-bottom: var(--wp--preset--spacing--insa-30);}",
                "elements": {
                    "cite": {
                        "typography": {
                            "fontSize": "var(--wp--preset--font-size--insa-small)",
                            "fontStyle": "normal"
                        }
                    }
                },
                "spacing": {
                    "padding": {
                        "bottom": "var(--wp--preset--spacing--insa-30)",
                        "top": "var(--wp--preset--spacing--insa-30)"
                    }
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--insa-xx-large)",
                    "fontWeight": "300",
                    "lineHeight": "1.2"
                }
            },
            "core/query-pagination": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--insa-medium)",
                    "fontWeight": "500"
                }
            },
            "core/quote": {
                "border": {
                    "color": "currentColor",
                    "style": "solid",
