                    "name": "Neutral Light",
                    "slug": "insa-neutral-light"
                },
                {
                    "color": "#7F8081",
                    "name": "Neutral",
                    "slug": "insa-neutral"
                },
                {
                    "color": "#4C4D4F",
                    "name": "Neutral Dark",
                    "slug": "insa-neutral-dark"
                },
                {
                    "color": "#191A1D",
                    "name": "Neutral Darker",
                    "slug": "insa-neutral-darker"
                },
                {
                    "color": "#000104",
                    "name": "Neutral Darkest",
                    "slug": "insa-neutral-darkest"
                },
                {
                    "color": "#E6E8ED",
                    "name": "Downriver Lightest",
                    "slug": "insa-downriver-lightest"
                },
                {
                    "color": "#CDD1DB",
                    "name": "Downriver Lighter",
                    "slug": "insa-downriver-lighter"
                },
                {
                    "color": "#515E83",
                    "name": "Downriver Light",
                    "slug": "insa-downriver-light"
                },
                {
                    "color": "#071A4E",
                    "name": "Downriver",
                    "slug": "insa-downriver"
                },
                {
                    "color": "#05143E",
                    "name": "Downriver Dark",
                    "slug": "insa-downriver-dark"
                },
                {
                    "color": "#020A1F",
                    "name": "Downriver Darker",
                    "slug": "insa-downriver-darker"
                },
                {
                    "color": "#020717",
                    "name": "Downriver Darkest",
                    "slug": "insa-downriver-darkest"
                },
                {
                    "color": "#F2EFEB",
                    "name": "Background",
                    "slug": "insa-background"
                }
            ]
        },
        "layout": {
            "contentSize": "1280px",
            "wideSize": "1440px"
        },
        "spacing": {
            "defaultSpacingSizes": false,
            "spacingSizes": [
                {
                    "name": "Edge Gap",
                    "size": "1rem",
                    "slug": "insa-edge-gap"
                },
                {
                    "name": "Elements Gap",
                    "size": "1.5rem",
                    "slug": "insa-elements-gap"
                },
                {
                    "name": "Small",
                    "size": "30px",
                    "slug": "insa-30"
                },
                {
                    "name": "Regular",
                    "size": "clamp(30px, 5vw, 50px)",
                    "slug": "insa-50"
                },
                {
                    "name": "Large",
                    "size": "clamp(30px, 7vw, 70px)",
                    "slug": "insa-60"
                },
                {
                    "name": "X-Large",
                    "size": "clamp(70px, 7vw, 100px)",
                    "slug": "insa-100"
                },
                {
                    "name": "Section Padding",
                    "size": "clamp(70px, 10vw, 100px)",
                    "slug": "insa-section-padding"
                }
            ],
            "units": ["%", "px", "em", "rem", "vh", "vw"]
        },
        "typography": {
            "defaultFontSizes": false,
            "fluid": true,
            "fontFamilies": [
                {
                    "name": "Plus Jakarta Sans",
                    "slug": "plus-jakarta-sans",
                    "fontFamily": "\"Plus Jakarta Sans\", sans-serif",
